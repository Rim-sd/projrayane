@{
    ViewData["Title"] = "Dashboard utilisateur";
}

<div class="dashboard-page">
    <div class="dashboard-header mb-4">
        <h1 class="mb-2">Bienvenue</h1>
        <p class="text-muted mb-0">Consultez les médicaments disponibles et gérez vos commandes.</p>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="dashboard-card h-100">
                <span class="dashboard-label">Médicaments</span>
                <p class="mb-3">Parcourir la liste des médicaments disponibles.</p>
                <a asp-controller="Medicament" asp-action="Liste" class="btn btn-primary">Voir la liste</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="dashboard-card h-100">
                <span class="dashboard-label">Commandes</span>
                <p class="mb-3">Suivre et passer vos commandes.</p>
                <a asp-controller="Commande" asp-action="Index" class="btn btn-primary">Mes commandes</a>
            </div>
        </div>
    </div>
</div>
